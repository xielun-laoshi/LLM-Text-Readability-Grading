# data/ holds raw downloads only and is regenerated by
# scripts/data_preprocessing.py -- keep the repo a recipe, not a data dump.
data/*
!data/.gitkeep

# Derived outputs: the unified-schema table, predictions, embeddings.
artifacts/*
!artifacts/.gitkeep

# Experiment run logs.
runs/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.venv/
venv/
.env

# Tooling / OS / notebooks
.ipynb_checkpoints/
.vscode/
.idea/
.DS_Store
Thumbs.db
